# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용(절대 클라이언트 노출 금지): Storage 업로드/관리에 사용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== 로그인 =====
# 공유 비밀번호 (둘이 함께 쓰는 1개)
SHARE_PASSWORD=change-me
# 세션 쿠키 서명용 시크릿 (openssl rand -base64 32 등으로 생성)
SESSION_SECRET=please-generate-a-long-random-secret

# ===== 지도/이동시간 =====
# 카카오 REST API 키 (지오코딩 + 자동차 길찾기)
KAKAO_REST_KEY=your-kakao-rest-key
# ODsay 대중교통 길찾기 API 키
ODSAY_KEY=your-odsay-key
